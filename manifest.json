{
  "manifest_version": 3,
  "name": "LinkedIn Connection Tracker",
  "version": "1.0.0",
  "description": "Track LinkedIn connection requests with reasons, statuses, task completion, and CSV export.",
  "permissions": ["storage", "downloads", "activeTab"],
  "host_permissions": ["*://*.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LinkedIn Connection Tracker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
