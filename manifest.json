{
  "manifest_version": 3,
  "name": "LinkedIn Connection Tracker",
  "version": "1.0.0",
  "description": "Track why you connect with people on LinkedIn. Prompts for a reason before sending connection requests and monitors status changes.",
  "permissions": ["storage", "downloads", "activeTab"],
  "host_permissions": ["*://*.linkedin.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Connection Tracker"
  }
}
